{
  "name": "finance-tracker-root",
  "version": "1.0.0",
  "description": "Root package for managing Personal Finance Tracker dev and build commands",
  "scripts": {
    "install-all": "npm install --prefix frontend",
    "backend:run": "mvn -f backend/pom.xml spring-boot:run",
    "frontend:run": "npm run dev --prefix frontend",
    "dev": "concurrently -n \"Backend,Frontend\" -c \"blue,green\" \"npm run backend:run\" \"npm run frontend:run\"",
    "frontend:build": "npm run build --prefix frontend",
    "build-and-run": "npm run frontend:build && npm run backend:run"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
